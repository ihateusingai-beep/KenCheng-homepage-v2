---
/**
 * SiteCard — reusable card used by index page (featured + default).
 *
 * V6 polish pass (2026-06-27):
 * - Hover micro-interaction: translateY(-2px) + cat-hue glow + radial overlay
 * - Cat-hue CSS var injected via inline style → all descendants (chip, link,
 *   badge, focus glow) all derive from it via `var(--cat-hue, fallback)`.
 * - Featured badge + left border stripe for visual differentiation.
 * - Title truncates with ellipsis on narrow widths; cat-chip stays full.
 *
 * Sprint 1 (2026-06-29): F2 health badge added — colour-coded dot in top-right.
 */
interface Props {
  title: string;
  url: string;
  category: string;
  body?: string;
  featured?: boolean;
  health?: 'alive' | 'redirect' | 'dead' | 'slow' | 'unverified' | 'blocked';
  /** @deprecated kept for back-compat; use `featured` only. */
  variant?: 'featured' | 'default';
}

const {
  title,
  url,
  category,
  body = '',
  featured = false,
  health = 'unverified',
  variant = 'default',
} = Astro.props;

const hostname = new URL(url).hostname.replace(/^www\./, '');

// Category → CSS var key (defined in global.css @theme tokens).
// Fallback to `other` for unknown categories — safe by default.
const CAT_VAR_MAP: Record<string, string> = {
  'AI': 'ai',
  '數學': 'math',
  '科學': 'science',
  '教學': 'teaching',
  '開發': 'dev',
  '設計': 'design',
  '學習': 'learning',
  '其他': 'other',
};
const catKey = CAT_VAR_MAP[category] ?? 'other';

const isFeatured = featured || variant === 'featured';

// Health badge meta
const HEALTH_META: Record<string, { label: string; cls: string; title: string }> = {
  alive:      { label: '●', cls: 'kc-health-alive',      title: '正常' },
  redirect:   { label: '→', cls: 'kc-health-redirect',   title: '跳轉' },
  dead:       { label: '✕', cls: 'kc-health-dead',       title: '失效' },
  slow:       { label: '◐', cls: 'kc-health-slow',      title: '緩慢' },
  unverified: { label: '?', cls: 'kc-health-unverified',  title: '未驗證' },
  blocked:    { label: '⊘', cls: 'kc-health-blocked',     title: '被擋（4xx，可能係 bot block）' },
};
const healthMeta = HEALTH_META[health] ?? HEALTH_META['unverified'];
---

<article
  class:list={['kc-card group kc-card-3d', isFeatured && 'kc-card-featured']}
  data-category={category}
  style={`--cat-hue: var(--color-cat-${catKey});`}
>
  <!-- Badges row: featured (left) + health (right) -->
  <div class="card-badges-row" aria-hidden="true">
    {isFeatured && (
      <span class="kc-card-featured-badge">★ FEATURED</span>
    )}
    <span
      class={`kc-health-dot ${healthMeta.cls}`}
      title={healthMeta.title}
      aria-label={healthMeta.title}
    >
      {healthMeta.label}
    </span>
  </div>

  <div class="flex items-start justify-between mb-2 gap-2">
    <h3 class="kc-card-title">{title}</h3>
    <span class="kc-card-cat-chip">{category}</span>
  </div>
  {body && <p class="kc-card-body line-clamp-3 mb-3">{body}</p>}
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="kc-card-link"
  >
    <span class="kc-card-hostname">{hostname}</span>
    <span class="kc-card-arrow" aria-hidden="true">→</span>
  </a>
</article>
