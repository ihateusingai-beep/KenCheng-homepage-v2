---
/**
 * SiteCard — reusable card used by index page (featured + default).
 *
 * V6 polish pass (2026-06-27):
 * - Hover micro-interaction: translateY(-2px) + cat-hue glow + radial overlay
 * - Cat-hue CSS var injected via inline style → all descendants (chip, link,
 *   badge, focus glow) derive from it via `var(--cat-hue, fallback)`.
 * - Featured badge + left border stripe for visual differentiation.
 * - Title truncates with ellipsis on narrow widths; cat-chip stays full.
 */
interface Props {
  title: string;
  url: string;
  category: string;
  body?: string;
  featured?: boolean;
  /** @deprecated kept for back-compat; use `featured` only. */
  variant?: 'featured' | 'default';
}

const {
  title,
  url,
  category,
  body = '',
  featured = false,
  variant = 'default',
} = Astro.props;

const hostname = new URL(url).hostname.replace(/^www\./, '');

// Category → CSS var key (defined in global.css @theme tokens).
// Fallback to `other` for unknown categories — safe by default.
const CAT_VAR_MAP: Record<string, string> = {
  'AI': 'ai',
  '教學': 'teaching',
  '開發': 'dev',
  '設計': 'design',
  '學習': 'learning',
  '其他': 'other',
};
const catKey = CAT_VAR_MAP[category] ?? 'other';

const isFeatured = featured || variant === 'featured';
---

<article
  class:list={['kc-card group', isFeatured && 'kc-card-featured']}
  data-category={category}
  style={`--cat-hue: var(--color-cat-${catKey});`}
>
  {isFeatured && (
    <div class="kc-card-featured-badge" aria-label="Featured">
      ★ FEATURED
    </div>
  )}
  <div class="flex items-start justify-between mb-2 gap-2">
    <h3 class="kc-card-title">{title}</h3>
    <span class="kc-card-cat-chip">{category}</span>
  </div>
  {body && <p class="kc-card-body line-clamp-3 mb-3">{body}</p>}
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class="kc-card-link"
  >
    <span class="kc-card-hostname">{hostname}</span>
    <span class="kc-card-arrow" aria-hidden="true">→</span>
  </a>
</article>
