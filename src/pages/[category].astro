---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteCard from '../components/SiteCard.astro';
import { getCollection } from 'astro:content';

// ── Category meta: display name, description, icon ────────────────────────────
const CAT_META: Record<string, { label: string; icon: string; desc: string }> = {
  '數學': {
    icon: '🔢',
    label: '數學',
    desc: '乘法、除法、減法、平面圖形、方程天平、位值認識——全部互動化，學生自己操作，唔再係死記硬背。適合 SEN 數學、課堂練習、家課。',
  },
  '科學': {
    icon: '🔬',
    label: '科學',
    desc: '水循環、浮力、溶解、蒸發、彩虹——全部係 SEN 科學必備嘅微觀模擬。互動式體驗，視覺化科學概念，唔需要實驗室設備。',
  },
  '教學': {
    icon: '📚',
    label: '教學',
    desc: '語文朗讀、成語闖關、歷史故事、課堂管理、分組工具——老師備課同課堂管理幫手，覆蓋語文、社會、課室各個範疇。',
  },
  'AI': {
    icon: '🤖',
    label: 'AI',
    desc: 'Claude、GPT、Phind、Gemini——實際應用喺教學嘅 AI 工具，唔係介紹而係真係用。涵蓋 prompt engineering、生成式 AI、搜尋增強。',
  },
  '開發': {
    icon: '⚙️',
    label: '開發',
    desc: 'Cursor、Vite、GitHub、Vercel——老師整自己工具嘅 stack，或者教學生 coding 嘅環境。從低代碼到全端都可以。',
  },
  '設計': {
    icon: '🎨',
    label: '設計',
    desc: 'Figma、Miro、AI Design——視覺化工具、教學簡報、UI/UX 概念探索。老師整教材視覺 collateral，或者學生接觸設計思維。',
  },
  '學習': {
    icon: '💡',
    label: '學習',
    desc: '打字練習、遊戲化學習、互動式藝術——打破傳統練習嘅沉悶，用遊戲機制提升動機。適合 starter 或者課後鞏固。',
  },
  '其他': {
    icon: '📌',
    label: '其他',
    desc: 'QR Code、打字、課室工具、Grouping、Meal——唔屬於上列範疇但有用嘅工具集合。',
  },
};

// All categories — used in both getStaticPaths AND template
const ALL_CATS = ['數學', '科學', '教學', 'AI', '開發', '設計', '學習', '其他'] as const;

// Generate one page per category
export async function getStaticPaths() {
  const sites = await getCollection('sites');
  const cats = ['數學', '科學', '教學', 'AI', '開發', '設計', '學習', '其他'];
  return cats.map((cat) => ({
    params: { category: cat },
    props: {
      sites: sites
        .filter((s) => s.data.category === cat)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { category } = Astro.params;
const { sites } = Astro.props;
const meta = CAT_META[category] ?? { icon: '📌', label: category, desc: '' };

// Slim payload for ⌘K palette
const paletteData = sites.map((s) => ({
  title: s.data.title,
  url: s.data.url,
  category: s.data.category,
  tags: s.data.tags,
  featured: s.data.featured,
  hostname: new URL(s.data.url).hostname.replace(/^www\./, ''),
}));

const totalCount = sites.length;
const featured = sites.filter((s) => s.data.featured);
---

<BaseLayout title={`${meta.label} — Ken Cheng 教學工具導航站`}>
  <script id="kc-sites-data" type="application/json" set:html={JSON.stringify(paletteData)} />

  <main id="main" class="container mx-auto px-4 py-12 max-w-6xl">

    <!-- Breadcrumb -->
    <nav class="mb-8" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-fg-dim font-mono">
        <li><a href="/KenCheng-homepage-v2/" class="text-accent hover:underline">🏠 主頁</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-fg">{meta.icon} {meta.label}</li>
      </ol>
    </nav>

    <!-- Category hero -->
    <header class="mb-10">
      <h1 class="text-3xl font-bold mb-3 flex items-center gap-3">
        <span class="text-accent">{meta.icon}</span>
        {meta.label}
      </h1>
      <p class="text-fg-dim text-base leading-relaxed max-w-2xl mb-6">
        {meta.desc}
      </p>
      <dl class="flex flex-wrap gap-6 text-sm font-mono">
        <div>
          <dt class="text-fg-dim text-xs uppercase tracking-wide mb-0.5">tools</dt>
          <dd class="text-xl font-bold text-accent">{totalCount}</dd>
        </div>
        <div>
          <dt class="text-fg-dim text-xs uppercase tracking-wide mb-0.5">featured</dt>
          <dd class="text-xl font-bold text-accent">{featured.length}</dd>
        </div>
        <div>
          <dt class="text-fg-dim text-xs uppercase tracking-wide mb-0.5">other categories</dt>
          <dd class="text-xl font-bold text-accent">{ALL_CATS.length - 1}</dd>
        </div>
      </dl>
    </header>

    <!-- Featured section (if any) -->
    {
      featured.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class="text-accent">★</span> 為你推薦
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {featured.slice(0, 6).map((site) => (
              <SiteCard
                title={site.data.title}
                url={site.data.url}
                category={site.data.category}
                body={site.body}
                featured={site.data.featured}
              />
            ))}
          </div>
        </section>
      )
    }

    <!-- All sites in this category -->
    <section>
      <h2 class="text-2xl font-semibold mb-6">
        全部 {meta.label} ({totalCount})
      </h2>
      {
        totalCount === 0 ? (
          <div class="text-center py-16 text-fg-dim">
            <p class="text-4xl mb-4">🔍</p>
            <p class="text-lg mb-2">呢個範疇暫時未有工具</p>
            <p class="text-sm">
              <a href="/KenCheng-homepage-v2/" class="text-accent hover:underline">返回主頁</a> 探索其他範疇
            </p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {sites.map((site) => (
              <SiteCard
                title={site.data.title}
                url={site.data.url}
                category={site.data.category}
                body={site.body}
              />
            ))}
          </div>
        )
      }
    </section>

    <!-- Category nav -->
    <nav class="mt-16 pt-8 border-t border-border" aria-label="Category navigation">
      <p class="text-sm text-fg-dim font-mono mb-4">其他範疇</p>
      <div class="flex flex-wrap gap-3">
        {
          ALL_CATS.filter((c) => c !== category).map((c) => {
            const m = CAT_META[c];
            return (
              <a
                href={`/KenCheng-homepage-v2/${c}/`}
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border border-border bg-bg-secondary text-fg hover:border-accent hover:text-accent transition-colors"
              >
                <span>{m?.icon ?? '📌'}</span>
                {m?.label ?? c}
              </a>
            );
          })
        }
      </div>
    </nav>

    <footer class="mt-12 pt-8 border-t border-border text-fg-faint text-sm font-mono">
      <p>
        <a href="/KenCheng-homepage-v2/" class="text-accent hover:underline">← 主頁</a> · v2 · {new Date().toISOString().split('T')[0]}
      </p>
    </footer>
  </main>
</BaseLayout>
