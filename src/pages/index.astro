---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteCard from '../components/SiteCard.astro';
import { getCollection } from 'astro:content';

const sites = await getCollection('sites');

// Slim payload for ⌘K palette
const paletteData = sites.map((s) => ({
  title: s.data.title,
  url: s.data.url,
  category: s.data.category,
  tags: s.data.tags,
  featured: s.data.featured,
  hostname: new URL(s.data.url).hostname.replace(/^www\./, ''),
  health: s.data.health ?? 'unverified',
}));

const featured = sites
  .filter((s) => s.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const categories = [...new Set(sites.map((s) => s.data.category))];
const aiCount = sites.filter((s) => s.data.category === 'AI').length;

// Category full meta — used in category showcase
const CAT_META: Record<string, { icon: string; hue: string; bg: string; desc: string }> = {
  '數學': {
    icon: '🔢', hue: '#f59e0b', bg: 'rgba(245,158,11,0.08)',
    desc: '乘法、減法、方程天平、位值認識——互動化，唔再死記硬背',
  },
  '科學': {
    icon: '🔬', hue: '#06b6d4', bg: 'rgba(6,182,212,0.08)',
    desc: '水循環、浮力、溶解、蒸發——微觀模擬，唔需要實驗室',
  },
  '教學': {
    icon: '📚', hue: '#10b981', bg: 'rgba(16,185,129,0.08)',
    desc: '語文朗讀、成語闖關、歷史故事、課堂管理',
  },
  'AI': {
    icon: '🤖', hue: '#00d4ff', bg: 'rgba(0,212,255,0.08)',
    desc: 'Claude、GPT、Phind——實際應用喺教學嘅 AI 工具',
  },
  '開發': {
    icon: '⚙️', hue: '#a855f7', bg: 'rgba(168,85,247,0.08)',
    desc: 'Cursor、GitHub、Vercel——老師整工具嘅 stack',
  },
  '設計': {
    icon: '🎨', hue: '#ec4899', bg: 'rgba(236,72,153,0.08)',
    desc: 'Figma、AI Design——視覺化工具，教學簡報、UI/UX 概念',
  },
  '學習': {
    icon: '💡', hue: '#f97316', bg: 'rgba(249,115,22,0.08)',
    desc: '打字練習、遊戲化學習——用遊戲機制提升動機',
  },
  '其他': {
    icon: '📌', hue: '#6b7280', bg: 'rgba(107,114,128,0.08)',
    desc: 'QR Code、課室工具、Grouping——有用嘅工具集合',
  },
};

const catCounts = Object.fromEntries(
  categories.map((cat) => [cat, sites.filter((s) => s.data.category === cat).length])
);
---

<BaseLayout title="Ken Cheng — 教學工具導航站">
  <script id="kc-sites-data" type="application/json" set:html={JSON.stringify(paletteData)} />

  <main id="main">

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="hero-section">
      <!-- Animated CSS grid background -->
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="container hero-inner">
        <!-- Label -->
        <div class="hero-label">
          <span class="label-bar"></span>
          <span>TOOL HUB</span>
          <span class="label-dot"></span>
        </div>

        <!-- Headline -->
        <h1 class="hero-headline">
          <span class="hero-headline-top">教學工具</span>
          <span class="hero-headline-mid">
            <span class="text-accent">AI</span>
            <span class="hero-headline-sep">·</span>
            <span>開發</span>
            <span class="hero-headline-sep">·</span>
            <span>科學</span>
          </span>
          <span class="hero-headline-bot">嘅 curated 目錄</span>
        </h1>

        <!-- Sub -->
        <p class="hero-sub">
          每個 site 都有實戰場景。<br class="hero-br" />
          唔係 aggregator，唔係 list——係揀過先放。
        </p>

        <!-- Featured CTA -->
        <a
          href="https://ihateusingai-beep.github.io/innovative-teaching-prompt-studio/"
          target="_blank"
          rel="noopener noreferrer"
          class="featured-cta"
        >
          <span class="featured-cta-icon">⭐</span>
          <span class="featured-cta-text">
            <strong>創意教學 Prompt Studio</strong>
            <small>特教教師必備 · AI Prompt 工作台</small>
          </span>
          <span class="featured-cta-arrow">→</span>
        </a>

        <!-- Stats row -->
        <div class="hero-stats-row">
          <div class="hero-stat">
            <span class="hero-stat-num">{sites.length}</span>
            <span class="hero-stat-label">tools</span>
          </div>
          <div class="hero-stat-sep" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">{categories.length}</span>
            <span class="hero-stat-label">範疇</span>
          </div>
          <div class="hero-stat-sep" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">{aiCount}</span>
            <span class="hero-stat-label">AI</span>
          </div>
          <div class="hero-stat-sep" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat-num">{featured.length}</span>
            <span class="hero-stat-label">featured</span>
          </div>
        </div>

        <!-- Search hint -->
        <p class="hero-hint">
          撳 <kbd class="kc-inline-kbd">⌘K</kbd> 或 <kbd class="kc-inline-kbd">/</kbd> 搜尋工具
        </p>
      </div>

      <!-- Category pills row -->
      <div class="hero-cat-row">
        <div class="container">
          <div class="hero-cats">
            {
              categories.map((cat) => {
                const m = CAT_META[cat];
                if (!m) return null;
                return (
                  <a href={`/KenCheng-homepage-v2/${cat}/`} class="hero-cat-pill" style={`--pill-hue: ${m.hue};`}>
                    <span class="hero-cat-icon">{m.icon}</span>
                    <span class="hero-cat-name">{cat}</span>
                    <span class="hero-cat-count">{catCounts[cat] ?? 0}</span>
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ── CATEGORY SHOWCASE ──────────────────────────────────── -->
    <section class="cat-showcase-section">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">範疇一覽</h2>
          <p class="section-sub">8 個範疇，每個都係精選</p>
        </div>

        <div class="cat-grid">
          {
            categories.map((cat, i) => {
              const m = CAT_META[cat];
              if (!m) return null;
              const count = catCounts[cat] ?? 0;
              return (
                  <a
                  href={`/KenCheng-homepage-v2/${cat}/`}
                  class:list={['cat-card reveal', i < 2 && 'cat-card--wide']}
                  style={`--card-hue: ${m.hue}; --card-bg: ${m.bg};`}
                >
                  <div class="cat-card-icon-wrap" aria-hidden="true">
                    <span class="cat-card-icon">{m.icon}</span>
                  </div>
                  <div class="cat-card-body">
                    <div class="cat-card-top">
                      <h3 class="cat-card-name">{cat}</h3>
                      <span class="cat-card-count">{count} tools</span>
                    </div>
                    <p class="cat-card-desc">{m.desc}</p>
                  </div>
                  <div class="cat-card-arrow" aria-hidden="true">→</div>
                  <div class="cat-card-glow" aria-hidden="true"></div>
                </a>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- ── FEATURED ─────────────────────────────────────────── -->
    {
      featured.length > 0 && (
        <section class="featured-section">
          <div class="container">
            <div class="section-header reveal">
              <div class="section-title-row">
                <h2 class="section-title">
                  <span class="text-accent">★</span> Featured
                </h2>
                <span class="section-badge">{featured.length} tools</span>
              </div>
              <p class="section-sub">Ken 親自維護嘅項目，全部實際用過</p>
            </div>

            <div class="featured-grid">
              {featured.slice(0, 4).map((site) => (
                <div class="reveal">
                  <SiteCard
                    title={site.data.title}
                    url={site.data.url}
                    category={site.data.category}
                    body={site.body}
                    featured={true}
                    health={site.data.health}
                  />
                </div>
              ))}
            </div>

            {featured.length > 4 && (
              <p class="featured-more reveal">
                + {featured.length - 4} more featured tools
              </p>
            )}
          </div>
        </section>
      )
    }

    <!-- ── ALL TOOLS ─────────────────────────────────────────── -->
    <section class="all-section">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-title-row">
            <h2 class="section-title">全部 tools</h2>
            <span class="section-badge">{sites.length} sites</span>
          </div>
        </div>

        <div class="all-grid">
          {sites
            .filter((s) => !s.data.featured)
            .sort((a, b) => a.data.order - b.data.order)
            .map((site) => (
              <div class="reveal">
                <SiteCard
                  title={site.data.title}
                  url={site.data.url}
                  category={site.data.category}
                  body={site.body}
                  health={site.data.health}
                />
              </div>
            ))}
        </div>
      </div>
    </section>

    <!-- ── FOOTER ──────────────────────────────────────────── -->
    <footer class="page-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-left">
            <p class="footer-label">// TOOL HUB</p>
            <p class="footer-sub">Ken Cheng · 2026 · v2</p>
          </div>
          <div class="footer-right">
            <a href="/KenCheng-homepage-v2/rss.xml" class="footer-link">RSS</a>
            <span class="footer-sep">·</span>
            <a href="/KenCheng-homepage-v2/sitemap-index.xml" class="footer-link">sitemap</a>
            <span class="footer-sep">·</span>
            <a href="https://github.com/ihateusingai-beep/kencheng-homepage-v2" class="footer-link" target="_blank" rel="noopener">
              GitHub
            </a>
          </div>
        </div>
      </div>
    </footer>

  </main>

  <!-- 3D Tilt — vanilla JS, no dependencies -->
  <script>
    function init3DTilt() {
      var cards = document.querySelectorAll<HTMLElement>('.kc-card-3d');
      if (!cards.length) return;
      cards.forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
          var evt = e as MouseEvent;
          var rect = card.getBoundingClientRect();
          var x = (evt.clientX - rect.left) / rect.width - 0.5;
          var y = (evt.clientY - rect.top) / rect.height - 0.5;
          if (document.documentElement.classList.contains('reduce-motion')) return;
          card.style.transform =
            'perspective(600px) rotateX(' + (-y * 10).toFixed(2) + 'deg) rotateY(' + (x * 10).toFixed(2) + 'deg) translateY(-3px) scale(1.02)';
        });
        card.addEventListener('mouseleave', function() {
          card.style.transform = '';
        });
      });
    }
    // Run after cards render
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init3DTilt);
    } else {
      init3DTilt();
    }
  </script>
</BaseLayout>
