---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteCard from '../components/SiteCard.astro';
import { getCollection } from 'astro:content';

const sites = await getCollection('sites');

// Slim payload for the ⌘K palette: only fields needed for search.
const paletteData = sites.map((s) => ({
  title: s.data.title,
  url: s.data.url,
  category: s.data.category,
  tags: s.data.tags,
  featured: s.data.featured,
  hostname: new URL(s.data.url).hostname.replace(/^www\./, ''),
}));

const featured = sites
  .filter((s) => s.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
const all = [...sites].sort((a, b) => a.data.order - b.data.order);

const categories = [...new Set(sites.map((s) => s.data.category))];
const aiCount = sites.filter((s) => s.data.category === 'AI').length;

// Category chip meta
const CAT_CHIP: Record<string, { icon: string; color: string }> = {
  '數學': { icon: '🔢', color: 'text-amber-500' },
  '科學': { icon: '🔬', color: 'text-cyan-600' },
  '教學': { icon: '📚', color: 'text-emerald-500' },
  'AI':   { icon: '🤖', color: 'text-cyan-400' },
  '開發': { icon: '⚙️', color: 'text-purple-500' },
  '設計': { icon: '🎨', color: 'text-pink-500' },
  '學習': { icon: '💡', color: 'text-orange-500' },
  '其他': { icon: '📌', color: 'text-gray-400' },
};

const catCounts = Object.fromEntries(
  categories.map((cat) => [cat, sites.filter((s) => s.data.category === cat).length])
);
---

<BaseLayout title="Ken Cheng — 教學工具導航站">
  <!-- F1 data source: read by command-palette.ts at runtime -->
  <script id="kc-sites-data" type="application/json" set:html={JSON.stringify(paletteData)} />

  <main id="main" class="container mx-auto px-4 py-12 max-w-6xl">
    <header class="kc-hero">
      <h1 class="kc-hero-title">
        <span class="text-accent">//</span> BOOKMARK_HUB_v2
      </h1>
      <p class="kc-hero-tagline">
        教學工具、AI 應用、開發工具嘅 curated 目錄。每個 site 都有實戰場景，
        唔係 aggregator。
      </p>
      <dl class="kc-hero-stats">
        <div class="kc-stat">
          <dt class="kc-stat-num">{sites.length}</dt>
          <dd class="kc-stat-label">sites</dd>
        </div>
        <div class="kc-stat">
          <dt class="kc-stat-num">{categories.length}</dt>
          <dd class="kc-stat-label">categories</dd>
        </div>
        <div class="kc-stat">
          <dt class="kc-stat-num">{aiCount}</dt>
          <dd class="kc-stat-label">AI tools</dd>
        </div>
      </dl>
      <p class="kc-hero-tip">
        Tip：撳 <kbd class="kc-inline-kbd">⌘K</kbd> /
        <kbd class="kc-inline-kbd">/</kbd> 開 search palette
      </p>
    </header>

    <!-- Category quick-nav chips -->
    <nav class="mb-10" aria-label="Category navigation">
      <p class="text-xs font-mono text-fg-dim uppercase tracking-wide mb-3">範疇</p>
      <div class="flex flex-wrap gap-3">
        {
          categories.map((cat) => {
            const chip = CAT_CHIP[cat] ?? { icon: '📌', color: 'text-gray-400' };
            const count = catCounts[cat] ?? 0;
            return (
              <a
                href={`/${cat}/`}
                class:list={[
                  'inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium',
                  'border border-border bg-bg-secondary',
                  'hover:border-accent hover:text-accent transition-colors',
                ]}
              >
                <span>{chip.icon}</span>
                <span>{cat}</span>
                <span class:list={['text-xs font-mono', chip.color, 'opacity-70']}>
                  {count}
                </span>
              </a>
            );
          })
        }
      </div>
    </nav>

    {
      featured.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-semibold mb-6 flex items-center gap-2">
            <span class="text-accent">★</span> 為你推薦
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {featured.slice(0, 6).map((site) => (
              <SiteCard
                title={site.data.title}
                url={site.data.url}
                category={site.data.category}
                body={site.body}
                featured={site.data.featured}
              />
            ))}
          </div>
        </section>
      )
    }

    <section>
      <h2 class="text-2xl font-semibold mb-6">全部</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {all.map((site) => (
          <SiteCard
            title={site.data.title}
            url={site.data.url}
            category={site.data.category}
            body={site.body}
          />
        ))}
      </div>
    </section>

    <footer class="mt-16 pt-8 border-t border-border text-fg-faint text-sm font-mono">
      <p>
        v2 scaffold · {new Date().toISOString().split('T')[0]} ·{' '}
        <a href="/rss.xml" class="text-accent hover:underline">RSS</a> ·{' '}
        <a href="/sitemap-index.xml" class="text-accent hover:underline">sitemap</a>
      </p>
    </footer>
  </main>
</BaseLayout>